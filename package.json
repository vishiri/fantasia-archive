{
  "name": "fantasia-archive",
  "version": "2.4.2",
  "description": "A worldbuilding database manager",
  "productName": "Fantasia Archive",
  "author": "Vishiri <vishiri.rilgatan@gmail.com>",
  "license": "GPL-3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "eslint --ext .js,.ts,.vue src src-electron e2e-tests types quasar.config.ts playwright.config.ts vitest.config.mts vitest.components.config.mts vitest.setup.ts testRunner_component.mjs testRunner_e2e.mjs .storybook-workspace/.storybook",
    "lint:types": "tsc -p tsconfig.json --pretty",
    "lint:style": "stylelint \"src/**/*.{vue,scss}\"",
    "dev:electron": "quasar dev -m electron",
    "build": "quasar build -m electron --publish never",
    "storybook": "yarn --cwd .storybook-workspace storybook",
    "build-storybook": "yarn --cwd .storybook-workspace build-storybook",
    "storybook:smoke": "yarn --cwd .storybook-workspace smoke-storybook",
    "test:unit": "vitest run && vitest run --config vitest.components.config.mts",
    "test:component": "node \"node_modules/@playwright/test/cli.js\" test src/components",
    "test:componentSingle": "node \"node_modules/@playwright/test/cli.js\" test src/components/%npm_config_component%",
    "test:componentSingleAuto": "node \"node_modules/@playwright/test/cli.js\" test %npm_config_component%",
    "test:componentList": "node testRunner_component.mjs",
    "test:e2e": "node \"node_modules/@playwright/test/cli.js\" test e2e-tests/",
    "test:e2eSingle": "node \"node_modules/@playwright/test/cli.js\" test e2e-tests/%npm_config_spec%.playwright.spec.ts",
    "test:e2eSingleAuto": "node \"node_modules/@playwright/test/cli.js\" test e2e-tests/%npm_config_spec%",
    "test:e2eList": "node testRunner_e2e.mjs",
    "test:full": "concurrently \"vitest run\" \"node \"node_modules/@playwright/test/cli.js\" test"
  },
  "dependencies": {
    "@electron/remote": "^2.1.3",
    "@quasar/extras": "^1.17.0",
    "@quasar/quasar-ui-qmarkdown": "^2.0.5",
    "app-root-path": "^3.1.0",
    "axios": "^1.14.0",
    "lodash-es": "^4.17.21",
    "pinia": "^2.3.1",
    "quasar": "^2.16.0",
    "sqlite3": "^5.1.6",
    "uuid": "^9.0.1",
    "vue": "^3.5.0",
    "vue-i18n": "^11",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@intlify/unplugin-vue-i18n": "^5.2.0",
    "@playwright/test": "^1.49.1",
    "@quasar/app-vite": "^2.5.0",
    "@quasar/cli": "^2.5.0",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-interactions": "^8.6.14",
    "@storybook/vue3-vite": "8.6.18",
    "@tmaize/prompts": "^2.4.3",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^22.10.0",
    "@types/prompts": "^2.4.9",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "electron": "^33.4.11",
    "electron-builder": "^26.0.0",
    "eslint": "^8.57.0",
    "eslint-config-standard": "^17.0.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-n": "^15.0.0",
    "eslint-plugin-promise": "^6.6.0",
    "eslint-plugin-vue": "^9.28.0",
    "jsdom": "^22.1.0",
    "playwright": "^1.49.1",
    "postcss": "^8.5.8",
    "postcss-html": "^1.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sass": "^1.78.0",
    "storybook": "8",
    "stylelint": "^15.10.3",
    "stylelint-config-standard": "^34.0.0",
    "stylelint-config-standard-scss": "^11.0.0",
    "stylelint-config-standard-vue": "^1.0.0",
    "typescript": "~5.6.0",
    "vite-plugin-checker": "^0.8.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22.22.0",
    "npm": ">= 6.13.4",
    "yarn": ">= 1.21.1"
  }
}
