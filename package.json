{
  "name": "fantasia-archive",
  "version": "2.4.9",
  "description": "A worldbuilding database manager",
  "productName": "Fantasia Archive",
  "author": "Vishiri <vishiri.rilgatan@gmail.com>",
  "license": "GPL-3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "lint:eslint": "eslint src src-electron e2e-tests types quasar.config.ts playwright.config.ts vitest.config.mts vitest.components.config.mts vitest.setup.ts testRunner_component.mjs testRunner_e2e.mjs .storybook-workspace/.storybook .storybook-workspace/playwright.storybook-visual.config.ts",
    "lint:stylelint": "stylelint \"src/**/*.{vue,scss}\"",
    "lint:typescript": "tsc -p tsconfig.json --pretty",
    "quasar:build:electron": "quasar build -m electron --publish never",
    "quasar:dev:electron": "quasar dev -m electron",
    "storybook:build": "yarn --cwd .storybook-workspace storybook:build",
    "storybook:run": "yarn --cwd .storybook-workspace storybook:run",
    "storybook:smoke": "yarn --cwd .storybook-workspace smoke-storybook",
    "test:components": "playwright test src/components",
    "test:components:list": "node testRunner_component.mjs",
    "test:components:single": "playwright test src/components/%npm_config_component%",
    "test:components:single:ci": "playwright test %npm_config_component%",
    "test:e2e": "playwright test e2e-tests/",
    "test:e2e:list": "node testRunner_e2e.mjs",
    "test:e2e:single": "playwright test e2e-tests/%npm_config_spec%.playwright.spec.ts",
    "test:e2e:single:ci": "playwright test e2e-tests/%npm_config_spec%",
    "test:unit": "vitest run && vitest run --config vitest.components.config.mts",
    "testbatch:ensure": "yarn testbatch:verify && yarn quasar:build:electron && yarn test:components && yarn test:e2e",
    "testbatch:verify": "yarn lint:eslint && yarn lint:typescript && yarn lint:stylelint && yarn test:unit",
    "visual:storybook:test": "yarn storybook:build && yarn --cwd .storybook-workspace storybook:visual:test",
    "visual:storybook:test:headed": "yarn storybook:build && yarn --cwd .storybook-workspace storybook:visual:test:headed",
    "visual:storybook:test:local": "yarn --cwd .storybook-workspace storybook:visual:test:local",
    "visual:storybook:update": "yarn storybook:build && yarn --cwd .storybook-workspace storybook:visual:update",
    "visual:storybook:update:headed": "yarn storybook:build && yarn --cwd .storybook-workspace storybook:visual:update:headed",
    "visual:storybook:update:local": "yarn --cwd .storybook-workspace storybook:visual:update:local"
  },
  "dependencies": {
    "@electron/remote": "^2.1.3",
    "@quasar/extras": "^1.17.0",
    "@quasar/quasar-ui-qmarkdown": "^2.0.5",
    "app-root-path": "^3.1.0",
    "axios": "^1.14.0",
    "lodash-es": "^4.18.1",
    "pinia": "^3.0.4",
    "quasar": "^2.16.0",
    "sqlite3": "^6.0.1",
    "uuid": "^13.0.0",
    "vue": "^3.5.0",
    "vue-i18n": "^11",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@intlify/unplugin-vue-i18n": "^11.0.7",
    "@playwright/test": "^1.49.1",
    "@quasar/app-vite": "^2.5.4",
    "@quasar/cli": "^3.0.0",
    "@storybook/vue3-vite": "10.3.4",
    "@stylistic/stylelint-config": "^5.0.0",
    "@tmaize/prompts": "^2.4.3",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^22.19.15",
    "@types/prompts": "^2.4.9",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.27",
    "electron": "^41.1.1",
    "electron-builder": "^26.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-storybook": "10.3.4",
    "eslint-plugin-vue": "^10.8.0",
    "jsdom": "^29.0.0",
    "neostandard": "^0.13.0",
    "playwright": "^1.49.1",
    "postcss": "^8.5.8",
    "postcss-html": "^1.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sass": "^1.78.0",
    "storybook": "10.3.4",
    "stylelint": "^17.6.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-config-standard-vue": "^1.0.0",
    "typescript": "~6.0.0",
    "typescript-eslint": "^8.58.0",
    "vite-plugin-checker": "^0.12.0",
    "vitest": "^4.1.2",
    "vue-eslint-parser": "^10.0.0"
  },
  "engines": {
    "node": ">=22.22.0",
    "npm": ">= 6.13.4",
    "yarn": ">= 1.21.1"
  }
}
