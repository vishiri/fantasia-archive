{
  "name": "fantasia-archive",
  "version": "2.4.10",
  "description": "A worldbuilding database manager",
  "productName": "Fantasia Archive",
  "author": "Vishiri <vishiri.rilgatan@gmail.com>",
  "license": "GPL-3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "lint:eslint": "eslint .",
    "lint:stylelint": "stylelint \"src/**/*.{vue,css,scss,sass}\" \".storybook-workspace/.storybook/**/*.{vue,css,scss,sass}\"",
    "lint:stylelint:fix": "stylelint \"src/**/*.{vue,css,scss,sass}\" \".storybook-workspace/.storybook/**/*.{vue,css,scss,sass}\" --fix",
    "lint:typescript": "vue-tsc -p tsconfig.json --noEmit",
    "quasar:build:electron": "quasar build -m electron --publish never",
    "quasar:build:electron:summarized": "node scripts/quasarBuildElectronSummarized.mjs",
    "quasar:dev:electron": "quasar dev -m electron",
    "storybook:build": "yarn --cwd .storybook-workspace storybook:build",
    "storybook:run": "yarn --cwd .storybook-workspace storybook:run",
    "test:components": "node scripts/playwrightWithArtifactTrim.mjs test src/components",
    "test:components:list": "node testRunner_component.mjs",
    "test:components:single": "node scripts/playwrightWithArtifactTrim.mjs test src/components/%npm_config_component%",
    "test:components:single:ci": "node scripts/playwrightWithArtifactTrim.mjs test %npm_config_component%",
    "test:e2e": "node scripts/playwrightWithArtifactTrim.mjs test e2e-tests/",
    "test:e2e:list": "node testRunner_e2e.mjs",
    "test:e2e:single": "node scripts/playwrightWithArtifactTrim.mjs test e2e-tests/%npm_config_spec%.playwright.spec.ts",
    "test:e2e:single:ci": "node scripts/playwrightWithArtifactTrim.mjs test e2e-tests/%npm_config_spec%",
    "test:storybook:smoke": "yarn --cwd .storybook-workspace test:storybook:smoke",
    "test:storybook:visual": "yarn storybook:build && yarn --cwd .storybook-workspace test:storybook:visual",
    "test:storybook:visual:headed": "yarn storybook:build && yarn --cwd .storybook-workspace test:storybook:visual:headed",
    "test:storybook:visual:update": "yarn storybook:build && yarn --cwd .storybook-workspace test:storybook:visual:update",
    "test:storybook:visual:update:headed": "yarn storybook:build && yarn --cwd .storybook-workspace test:storybook:visual:update:headed",
    "test:unit": "vitest run",
    "test:coverage:electron": "vitest run --coverage --config vitest/vitest.electron.config.mts",
    "test:coverage:helpers": "vitest run --coverage --config vitest/vitest.helpers.config.mts",
    "test:coverage:src": "vitest run --coverage --config vitest/vitest.src-renderer.config.mts && vitest run --coverage --config vitest/vitest.components.config.mts",
    "test:coverage:verify": "yarn test:coverage:electron && yarn test:coverage:helpers && yarn test:coverage:src",
    "test:unit:coverage": "yarn test:coverage:verify",
    "testbatch:verify": "yarn lint:eslint && yarn lint:typescript && yarn lint:stylelint && yarn test:coverage:verify",
    "testbatch:ensure:change": "yarn testbatch:verify && yarn quasar:build:electron:summarized && yarn test:components && yarn test:e2e && yarn test:storybook:smoke && yarn test:storybook:visual:update",
    "testbatch:ensure:nochange": "yarn testbatch:verify && yarn quasar:build:electron:summarized && yarn test:components && yarn test:e2e && yarn test:storybook:smoke && yarn test:storybook:visual"
  },
  "dependencies": {
    "@electron/remote": "^2.1.3",
    "@quasar/extras": "^1.17.0",
    "@quasar/quasar-ui-qmarkdown": "^2.0.5",
    "app-root-path": "^3.1.0",
    "axios": "^1.14.0",
    "better-sqlite3": "^12.8.0",
    "electron-store": "^11.0.2",
    "lodash-es": "^4.18.1",
    "pinia": "^3.0.4",
    "quasar": "^2.16.0",
    "uuid": "^13.0.0",
    "vue": "^3.5.32",
    "vue-i18n": "^11",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@intlify/unplugin-vue-i18n": "^11.0.7",
    "@playwright/test": "^1.49.1",
    "@quasar/app-vite": "^2.5.4",
    "@quasar/cli": "^3.0.0",
    "@storybook/vue3-vite": "10.3.4",
    "@stylistic/stylelint-config": "^5.0.0",
    "@tmaize/prompts": "^2.4.3",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^22.19.17",
    "@types/prompts": "^2.4.9",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/coverage-v8": "4.1.2",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.27",
    "electron": "^41.1.1",
    "electron-builder": "^26.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-storybook": "10.3.4",
    "eslint-plugin-vue": "^10.8.0",
    "jsdom": "^29.0.0",
    "neostandard": "^0.13.0",
    "playwright": "^1.49.1",
    "postcss": "^8.5.8",
    "postcss-html": "^1.8.1",
    "postcss-sass": "^0.5.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sass": "^1.78.0",
    "storybook": "10.3.4",
    "stylelint": "^17.6.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-config-standard-vue": "^1.0.0",
    "stylelint-order": "^8.1.1",
    "typescript": "~6.0.0",
    "typescript-eslint": "^8.58.0",
    "vite-plugin-checker": "^0.12.0",
    "vitest": "^4.1.2",
    "vue-eslint-parser": "^10.0.0",
    "vue-tsc": "^2.2.0"
  },
  "engines": {
    "node": ">=22.22.0",
    "npm": ">= 6.13.4",
    "yarn": ">= 1.21.1"
  }
}
