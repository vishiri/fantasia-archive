{
  "name": "fantasia-archive",
  "version": "2.4.8",
  "description": "A worldbuilding database manager",
  "productName": "Fantasia Archive",
  "author": "Vishiri <vishiri.rilgatan@gmail.com>",
  "license": "GPL-3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "eslint src src-electron e2e-tests types quasar.config.ts playwright.config.ts vitest.config.mts vitest.components.config.mts vitest.setup.ts testRunner_component.mjs testRunner_e2e.mjs .storybook-workspace/.storybook",
    "lint:types": "tsc -p tsconfig.json --pretty",
    "lint:style": "stylelint \"src/**/*.{vue,scss}\"",
    "verify": "yarn lint && yarn lint:types && yarn lint:style && yarn test:unit",
    "dev:electron": "quasar dev -m electron",
    "build": "quasar build -m electron --publish never",
    "storybook": "yarn --cwd .storybook-workspace storybook",
    "build-storybook": "yarn --cwd .storybook-workspace build-storybook",
    "storybook:smoke": "yarn --cwd .storybook-workspace smoke-storybook",
    "test:unit": "vitest run && vitest run --config vitest.components.config.mts",
    "test:component": "node \"node_modules/@playwright/test/cli.js\" test src/components",
    "test:componentSingle": "node \"node_modules/@playwright/test/cli.js\" test src/components/%npm_config_component%",
    "test:componentSingleAuto": "node \"node_modules/@playwright/test/cli.js\" test %npm_config_component%",
    "test:componentList": "node testRunner_component.mjs",
    "test:e2e": "node \"node_modules/@playwright/test/cli.js\" test e2e-tests/",
    "test:e2eSingle": "node \"node_modules/@playwright/test/cli.js\" test e2e-tests/%npm_config_spec%.playwright.spec.ts",
    "test:e2eSingleAuto": "node \"node_modules/@playwright/test/cli.js\" test e2e-tests/%npm_config_spec%",
    "test:e2eList": "node testRunner_e2e.mjs",
    "test:full": "yarn test:unit && node node_modules/@playwright/test/cli.js test src/components e2e-tests/"
  },
  "dependencies": {
    "@electron/remote": "^2.1.3",
    "@quasar/extras": "^1.17.0",
    "@quasar/quasar-ui-qmarkdown": "^2.0.5",
    "app-root-path": "^3.1.0",
    "axios": "^1.14.0",
    "lodash-es": "^4.18.1",
    "pinia": "^3.0.4",
    "quasar": "^2.16.0",
    "sqlite3": "^6.0.1",
    "uuid": "^13.0.0",
    "vue": "^3.5.0",
    "vue-i18n": "^11",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@intlify/unplugin-vue-i18n": "^11.0.7",
    "@playwright/test": "^1.49.1",
    "@quasar/app-vite": "^2.5.4",
    "@quasar/cli": "^3.0.0",
    "@storybook/vue3-vite": "10.3.4",
    "@stylistic/stylelint-config": "^5.0.0",
    "@tmaize/prompts": "^2.4.3",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^22.19.15",
    "@types/prompts": "^2.4.9",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.27",
    "electron": "^33.4.11",
    "electron-builder": "^26.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-storybook": "10.3.4",
    "eslint-plugin-vue": "^10.8.0",
    "jsdom": "^29.0.0",
    "neostandard": "^0.13.0",
    "playwright": "^1.49.1",
    "postcss": "^8.5.8",
    "postcss-html": "^1.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sass": "^1.78.0",
    "storybook": "10.3.4",
    "stylelint": "^17.6.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-config-standard-vue": "^1.0.0",
    "typescript": "~6.0.0",
    "typescript-eslint": "^8.58.0",
    "vite-plugin-checker": "^0.12.0",
    "vitest": "^4.1.2",
    "vue-eslint-parser": "^10.0.0"
  },
  "engines": {
    "node": ">=22.22.0",
    "npm": ">= 6.13.4",
    "yarn": ">= 1.21.1"
  }
}
