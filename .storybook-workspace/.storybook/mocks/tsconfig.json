{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "lib": [
      "ESNext",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "paths": {
      "app": [
        "../../.."
      ],
      "app/*": [
        "../../../*"
      ],
      "src": [
        "../../../src"
      ],
      "src/*": [
        "../../../src/*"
      ]
    },
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ESNext",
    "types": [
      "node"
    ]
  },
  "include": [
    "./**/*.ts",
    "../../../src/env.d.ts",
    "../../../src/globals.d.ts"
  ]
}
