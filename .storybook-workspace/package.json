{
  "name": "fantasia-archive-storybook-workspace",
  "private": true,
  "type": "module",
  "scripts": {
    "storybook:build": "storybook build -c .storybook -o storybook-static --disable-telemetry",
    "storybook:run": "storybook dev -p 6006 -c .storybook --disable-telemetry",
    "test:storybook:smoke": "storybook dev -p 6006 -c .storybook --smoke-test --ci --disable-telemetry",
    "test:storybook:visual": "playwright test --config playwright.storybook-visual.config.ts",
    "test:storybook:visual:headed": "playwright test --config playwright.storybook-visual.config.ts --headed",
    "test:storybook:visual:update": "playwright test --config playwright.storybook-visual.config.ts --update-snapshots",
    "test:storybook:visual:update:headed": "playwright test --config playwright.storybook-visual.config.ts --update-snapshots --headed"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@quasar/extras": "^1.17.0",
    "@quasar/quasar-ui-qmarkdown": "^2.0.5",
    "@storybook/addon-docs": "10.3.4",
    "@storybook/vue3-vite": "10.3.4",
    "@vitejs/plugin-vue": "^6.0.5",
    "http-server": "^14.1.1",
    "pinia": "^3.0.4",
    "playwright": "^1.49.1",
    "quasar": "^2.16.0",
    "sass": "^1.78.0",
    "storybook": "10.3.4",
    "vite": "^8.0.5",
    "vue": "^3.5.32",
    "vue-i18n": "^11.0.0",
    "vue-router": "^5.0.4"
  }
}
