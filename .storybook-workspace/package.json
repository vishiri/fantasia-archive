    "@storybook/vue3-vite": "10.3.4",
    "@vitejs/plugin-vue": "^6.0.5",
    "pinia": "^2.3.1",
    "quasar": "^2.16.0",
    "sass": "^1.78.0",
    "storybook": "10.3.4",
    "vite": "^8.0.3",
    "vue": "^3.5.0",
    "vue-i18n": "^11.0.0"
  }
}
