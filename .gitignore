npm-debug.log*
yarn-debug.log*
yarn-error.log*
debug-storybook.log*

# Editor directories and files
.idea
*.suo
*.ntvs*
*.njsproj
*.sln

# Playwright MCP (Cursor MCP server local workspace state; not app test output)
.playwright-mcp/

