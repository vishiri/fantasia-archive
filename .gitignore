# Legacy root output from older Storybook build paths (ignored; use `.storybook-workspace/storybook-static` only)
/storybook-static

# Loki visual regression output (deprecated; Storybook VRT uses Playwright)
**/.loki/
/quasar.config.*.temporary.compiled*

# Cordova related directories and files
/src-cordova/node_modules
/src-cordova/platforms
/src-cordova/plugins
/src-cordova/www

# Capacitor related directories and files
/src-capacitor/www
/src-capacitor/node_modules

# BEX related directories and files
/src-bex/www
/src-bex/js/core

